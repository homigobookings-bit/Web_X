namespace Mobility { 
 
export class Machine { 
    company: string; 
 
    constructor(company: string) { 
        this.company = company; 
    } 
 
    ignite(): void { 
        console.log(this.company + " machine is now running."); 
    } 
} 
 
} 
Exp3.2.ts:- 
/// <reference path="Exp3.1.ts" /> 
 
namespace Mobility { 
 
export class Bike extends Machine { 
 
    engineType: string; 
 
    constructor(company: string, engineType: string) { 
        super(company); 
        this.engineType = engineType; 
    } 
 
    details(): void { 
        console.log("Company Name:", this.company); 
        console.log("Engine Type:", this.engineType); 
    } 
} 
 
} 
 
let b1 = new Mobility.Bike("Honda", "Petrol"); 
 
b1.ignite(); 
b1.details();
