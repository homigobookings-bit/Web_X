A]Create a student records from using angular js 
Code:index.html:- 
<!DOCTYPE html> 
<html ng-app="myApp"> 
<head> 
    <title>Student Record Form</title> 
    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>     
<script src="app.js"></script> 
    <style>         table, th, td {             
border: 1px solid black;             
border-collapse: collapse;             
padding: 5px; 
        } 
    </style> 
</head> 
<body ng-controller="myCtrl"> 
    <h3>Student Record Form</h3> 
    <!-- MAIN TABLE --> 
    <table> 
        <tr> 
            <th>Sr No.</th> 
            <th>Col 1</th> 
            <th>Col 2</th> 
        </tr> 
        <tr> 
            <td>1</td> 
            <td>First Name</td> 
            <td><input type="text" ng-model="firstName"></td> 
        </tr> 
        <tr> 
            <td>2</td> 
            <td>Last Name</td> 
            <td><input type="text" ng-model="lastName"></td> 
        </tr> 
        <tr> 
            <td>3</td> 
            <td>Full Name</td> 
            <td>{{firstName + ' ' + lastName}}</td>         
</tr> 
        <tr> 
            <td>4</td> 
            <td>Subjects</td> 
            <td> 
                <!-- INNER TABLE --> 
                <table> 
                    <tr> 
                        <th>Subject</th> 
                        <th>IA 1</th> 
                        <th>IA 2</th> 
                        <th>Average</th> 
                    </tr> 
                    <tr> 
                        <td><input type="text" ng-model="sub1"></td> 
                        <td><input type="number" ng-model="s1_1"></td> 
                        <td><input type="number" ng-model="s1_2"></td> 
                        <td>{{ (s1_1 + s1_2) / 2 }}</td>                     
</tr> 
                    <tr> 
                        <td><input type="text" ng-model="sub2"></td> 
                        <td><input type="number" ng-model="s2_1"></td> 
                        <td><input type="number" ng-model="s2_2"></td> 
                        <td>{{ (s2_1 + s2_2) / 2 }}</td>                     
</tr> 
                    <tr> 
                        <td><input type="text" ng-model="sub3"></td> 
                        <td><input type="number" ng-model="s3_1"></td> 
                        <td><input type="number" ng-model="s3_2"></td> 
                        <td>{{ (s3_1 + s3_2) / 2 }}</td>                     
</tr> 
                    <tr> 
                        <td><input type="text" ng-model="sub4"></td> 
                        <td><input type="number" ng-model="s4_1"></td> 
                        <td><input type="number" ng-model="s4_2"></td> 
                        <td>{{ (s4_1 + s4_2) / 2 }}</td>                     
</tr> 
                </table> 
            </td>         
</tr> 
    </table> 
    <br> 
    <!-- SUBMIT BUTTON --> 
    <button>Submit</button> 
</body> 
</html> 



app.js:var app = 
angular.module("myApp", []); 
app.controller("myCtrl", function($scope) { 
    $scope.firstName = ""; 
    $scope.lastName = ""; 
});


B] To implement a single page application using angular js and routing  
Code:- 
index.html:- 
<!DOCTYPE html> 
<html ng-app="myApp"> 
<head> 
    <title>AngularJS SPA</title> 
    <!-- AngularJS + Routing --> 
    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script> 
    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular
route.js"></script> 
    <script src="app.js"></script> 
    <style> 
        a {             
margin: 10px; 
            text-decoration: none; 
        } 
    </style> 
</head> 
<body> 
    <h2>Single Page Application</h2> 
    <!-- Navigation --> 
    <a href="#!/">Home</a> 
    <a href="#!/about">About Us</a> 
    <a href="#!/shop">Shop</a> 
    <a href="#!/contact">Contact Us</a> 
    <hr> 
    <!-- View loads here --> 
    <div ng-view></div> 
</body> 
</html> 
app.js:var app = angular.module("myApp", 
["ngRoute"]); 
// ROUTING CONFIG 
app.config(function($routeProvider) { 
    $routeProvider 
    .when("/", { 
        template: "<h3>Home Page</h3><p>Welcome to our website.</p>" 
    }) 
    .when("/about", { 
        template: "<h3>About Us</h3><p>This is the about page.</p>" 
    }) 
    .when("/shop", { 
        template: "<h3>Shop</h3><p>Here you can buy products.</p>" 
    }) 
    .when("/contact", { 
        template: "<h3>Contact Us</h3><p>Contact us at example@email.com</p>" 
    }) 
    .otherwise({         
redirectTo: "/"     }); 
});
