<!DOCTYPE html>
<html ng-app="myApp">
<head>
    <title>Custom Directives Example</title>
    <!-- AngularJS CDN -->
    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>
    <!-- Link JS file -->
    <script src="app.js"></script>
    <style>
        .box {
            border: 1px solid black;
            padding: 10px;
            width: 300px;
        }
        .highlight {
            background-color: lightgray;
            padding: 3px;
        }
    </style>
</head>
<body ng-controller="myCtrl">
    <!-- BOX DIRECTIVE -->
    <my-box>
        <p>BOX DIRECTIVE</p>
        <!-- TEXT DIRECTIVE -->
        <p>TEXT DIRECTIVE</p>
        <my-text></my-text>
        <!-- INPUT DIRECTIVE -->
        <p>INPUT DIRECTIVE</p>
        <my-input></my-input>
        <!-- OUTPUT -->
        <p>OUTPUT</p>
        <p>You Entered: {{userInput}}</p>
    </my-box>
</body>
</html>


ap.js:
var app = angular.module("myApp", []);
// CONTROLLER
app.controller("myCtrl", function($scope) {
    $scope.userInput = "";
});
// BOX DIRECTIVE
app.directive("myBox", function() {
    return {
        restrict: "E",
        transclude: true,
        template: '<div class="box" ng-transclude></div>'
    };
});
// TEXT DIRECTIVE
app.directive("myText", function() {
    return {
        restrict: "E",
        template: '<div class="highlight">Enter Something:</div>'
    };
});
// INPUT DIRECTIVE
app.directive("myInput", function() {
    return {
        restrict: "E",
        template: '<input type="text" ng-model="userInput" />'
    };
});
