1] Create a simple HTML“Hello World” Project using AngularJS Framework
Index.html:
<!DOCTYPEhtml>
<html ng-app="myApp">
<head>
<title>AngularJS Hello World</title>
<!-- AngularJS CDN-->
<script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>
<!-- Custom JS-->
<script src="app.js"></script>
</head>
<body ng-controller="MainController">
<h1>{{ message }}</h1>
</body>
</html>
App.js:
// Create AngularJS Module
var app=angular.module("myApp", []);
// Create Controller
app.controller("MainController",function($scope){
$scope.message = "Hello World from AngularJS!";
});


2] UseVariables and Arrays in simple HTML Project using AngularJS Framework
Index2.html:
<!DOCTYPE html>
<html ng-app="myApp">
<head>
<title>AngularJS Variables and Arrays</title>
<!-- AngularJS CDN-->
<script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>
<!-- JS File-->
<script src="app.js"></script>
</head>
<body ng-controller="MainController">
<h1>{{title}}</h1>
<h2>Student Name: {{studentName}}</h2>
<!-- Input Field-->
<input type="text" ng-model="newSubject" placeholder="Enter subject">
<!-- Button-->
<button ng-click="addSubject()">Add Subject</button>
<h3>Subjects:</h3>
<ul>
<li ng-repeat="subject in subjects">
{{subject}}
</li>
</ul>
</body>
</html>
App.js:
var app = angular.module("myApp", []);
app.controller("MainController", function($scope){
$scope.title = "AngularJS Variables and Arrays Example";
$scope.studentName = "Shreyas";
// Start with empty array
$scope.subjects = [];
// Function to add subject
$scope.addSubject = function(){
if($scope.newSubject){
$scope.subjects.push($scope.newSubject);
$scope.newSubject = ""; // clear input
}
};
});});


3] Create a simple Background Color changing Project in HTML using AngularJS Framework
Index.html:
<!DOCTYPEhtml>
<html ng-app="myApp">
<head>
<title>Background Color Change</title>
<!-- AngularJS CDN-->
<script
src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>
<script src="app.js"></script>
</head>
<bodyng-controller="MainController"ng-style="{'background-color': bgColor}">
<h1>{{title}}</h1>
<!-- Simple input box-->
<input type="text" ng-model="bgColor"placeholder="Enter color (red,yellow, green)">
</body>
</html>
App.js:
var app=angular.module("myApp", []);
app.controller("MainController", function($scope){
$scope.title = "Enter Color to Change Background";
$scope.bgColor = "white"; // default color
});



